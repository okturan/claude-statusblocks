{
  "target_strict_score": 95,
  "review_max_age_days": 30,
  "review_batch_max_files": 80,
  "holistic_max_age_days": 30,
  "generate_scorecard": true,
  "badge_path": "scorecard.png",
  "exclude": [
    "dist",
    "node_modules",
    "coverage"
  ],
  "ignore": [
    "test_coverage::src/colors.ts",
    "test_coverage::src/config.ts",
    "test_coverage::src/config.ts::untested_module",
    "test_coverage::src/layout.ts",
    "test_coverage::src/campaigns/engine.ts",
    "test_coverage::src/campaigns/data.ts",
    "test_coverage::src/colors.ts::untested_module",
    "test_coverage::src/effort.ts",
    "test_coverage::src/cli.ts",
    "test_coverage::src/cli.ts::untested_module",
    "test_coverage::src/index.ts",
    "test_coverage::src/index.ts::untested_module",
    "test_coverage::src/segments/context.ts",
    "test_coverage::src/segments/model.ts",
    "test_coverage::src/segments/git.ts"
  ],
  "ignore_metadata": {},
  "zone_overrides": {},
  "review_dimensions": [],
  "large_files_threshold": 0,
  "props_threshold": 0,
  "issue_noise_budget": 10,
  "issue_noise_global_budget": 0,
  "execution_log_max_entries": 10000,
  "needs_rescan": true,
  "languages": {},
  "commit_tracking_enabled": true,
  "commit_pr": 0,
  "commit_default_branch": "",
  "commit_message_template": "desloppify: {status} {count} issue(s) \u2014 {summary}",
  "trust_plugins": false,
  "transition_messages": {},
  "hermes_enabled": false,
  "hermes_models": {
    "execute": "openrouter:x-ai/grok-4.20-beta",
    "review": "openrouter:google/gemini-3.1-pro-preview"
  }
}
